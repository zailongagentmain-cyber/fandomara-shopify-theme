{% comment %}
    Pixel-Perfect Refined Product Card for Fandomara
{% endcomment %}

<div class="product-card">
  <a href="{{ product.url }}" class="product-card__link">
    <div class="product-card__image-wrapper">
      {%- if product.featured_media != blank -%}
        <img
          src="{{ product.featured_media | image_url: width: 600 }}"
          alt="{{ product.featured_media.alt | escape }}"
          class="product-card__image"
          loading="lazy"
        >
        {%- if product.media[1] != blank -%}
          <img
            src="{{ product.media[1] | image_url: width: 600 }}"
            alt="{{ product.media[1].alt | escape }}"
            class="product-card__image product-card__image--hover"
            loading="lazy"
          >
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      
      {%- if product.compare_at_price > product.price -%}
        <span class="product-card__badge">SALE</span>
      {%- endif -%}
    </div>

    <div class="product-card__info">
      <h3 class="product-card__title">{{ product.title | escape }}</h3>
      <div class="product-card__price">
        {%- if product.compare_at_price > product.price -%}
          <span class="price-item price-item--regular">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
        <span class="price-item price-item--sale">{{ product.price | money }}</span>
      </div>
    </div>
  </a>
</div>

<style>
  .product-card {
    position: relative;
    text-align: left;
  }
  .product-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .product-card__image-wrapper {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f9f9f9; /* 原站那种极浅灰背景 */
    border-radius: 2px;
  }
  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .product-card__image--hover {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .product-card__link:hover .product-card__image {
    transform: scale(1.05);
  }
  .product-card__link:hover .product-card__image--hover {
    opacity: 1;
  }
  .product-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #000; /* 原站 badge 通常是黑色或红色 */
    color: #fff;
    padding: 5px 10px;
    font-size: 10px;
    letter-spacing: 0.1em;
    font-weight: 700;
    z-index: 2;
  }
  .product-card__title {
    font-size: 13px; /* 原站字号较小，显得精致 */
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 15px 0 8px;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .product-card__price {
    font-size: 15px;
    font-weight: 700;
  }
  .price-item--regular {
    text-decoration: line-through;
    color: #999;
    font-weight: 400;
    margin-right: 10px;
  }
  .price-item--sale {
    color: var(--color-accent);
  }
</style>
