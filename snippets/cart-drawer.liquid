<div id="CartDrawer" class="drawer drawer--right">
  <div class="drawer__header">
    <h2 class="drawer__title">CART</h2>
    <button type="button" class="drawer__close" onclick="closeDrawer('CartDrawer')">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
  
  <div id="CartDrawerContent" class="drawer__content">
    {%- if cart.item_count > 0 -%}
      <div class="drawer__cart-items">
        {%- for item in cart.items -%}
          <div class="drawer__cart-item">
            <div class="cart-item__image">
              <img src="{{ item.image | image_url: width: 150 }}" alt="{{ item.title }}" loading="lazy">
            </div>
            <div class="cart-item__info">
              <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title }}</a>
              {%- unless item.product.has_only_default_variant -%}
                <p class="cart-item__variant">{{ item.variant.title }}</p>
              {%- endunless -%}
              <div class="cart-item__price-qty">
                 <span>{{ item.final_price | money }}</span>
                 <div class="mini-qty-selector">
                   <button type="button">-</button>
                   <input type="text" value="{{ item.quantity }}" readonly>
                   <button type="button">+</button>
                 </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
      
      <div class="drawer__footer-refined">
        <div class="drawer__subtotal-row">
          <span>SUBTOTAL</span>
          <span class="subtotal-amount">{{ cart.total_price | money }}</span>
        </div>
        <p class="drawer__disclaimer">Taxes and shipping calculated at checkout</p>
        <button class="drawer__checkout-btn-refined">CHECK OUT</button>
      </div>
    {%- else -%}
      <div class="drawer__empty-state">
        <p>Your cart is empty</p>
        <a href="/collections/all" class="drawer__continue-btn-refined">CONTINUE SHOPPING</a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  /* Refined Cart Drawer Styles */
  .drawer__title { font-size: 1.4rem; letter-spacing: 0.2em; font-weight: 600; }
  .cart-item__name { font-size: 1.4rem; font-weight: 500; color: #121212; text-decoration: none; }
  .cart-item__variant { font-size: 1.2rem; color: rgba(18, 18, 18, 0.5); margin: 5px 0; }
  
  .cart-item__price-qty { display: flex; justify-content: space-between; align-items: center; margin-top: 10px; font-size: 1.3rem; }
  .mini-qty-selector { display: flex; border: 1px solid #eee; }
  .mini-qty-selector button { background: none; border: none; padding: 2px 8px; cursor: pointer; }
  .mini-qty-selector input { width: 30px; border: none; text-align: center; font-size: 1.2rem; }

  .drawer__footer-refined { padding: 25px; border-top: 1px solid #eee; }
  .drawer__subtotal-row { display: flex; justify-content: space-between; font-weight: 600; font-size: 1.4rem; margin-bottom: 10px; letter-spacing: 0.1em; }
  .drawer__disclaimer { font-size: 1.1rem; color: #888; text-align: center; margin-bottom: 25px; }
  
  .drawer__checkout-btn-refined { 
    width: 100%; 
    height: 48px; 
    background: #121212; 
    color: #fff; 
    border: none; 
    font-weight: 600; 
    letter-spacing: 0.15em; 
    cursor: pointer;
    transition: box-shadow 0.1s ease;
  }
  .drawer__checkout-btn-refined:hover { box-shadow: 0 0 0 0.1rem #121212; }

  .drawer__empty-state { text-align: center; padding: 100px 0; }
  .drawer__continue-btn-refined { 
    display: inline-block; 
    margin-top: 20px; 
    padding: 15px 30px; 
    background: #121212; 
    color: #fff; 
    text-decoration: none; 
    font-size: 1.2rem; 
    font-weight: 600; 
    letter-spacing: 0.1em;
  }
</style>
