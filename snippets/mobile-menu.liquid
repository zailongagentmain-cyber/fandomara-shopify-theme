<div id="MobileMenu" class="drawer drawer--left">
  <div class="drawer__header">
    <h2 class="drawer__title">MENU</h2>
    <button type="button" class="drawer__close" aria-label="Close menu" onclick="closeDrawer('MobileMenu')">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
  
  <div class="drawer__content">
    <nav class="mobile-navigation">
      <ul class="mobile-nav-list">
        {%- for link in linklists.main-menu.links -%}
          <li class="mobile-nav-item">
            <a href="{{ link.url }}" class="mobile-nav-link {% if link.active %}is-active{% endif %}">
              {{ link.title | uppercase }}
              {% if link.links.size > 0 %}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
              {% endif %}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <div class="mobile-menu-footer">
      <div class="mobile-account-links">
        {%- if shop.customer_accounts_enabled -%}
          <a href="{{ routes.account_login_url }}" class="mobile-footer-link">LOG IN</a>
          <a href="{{ routes.account_register_url }}" class="mobile-footer-link">CREATE ACCOUNT</a>
        {%- endif -%}
      </div>
      <div class="mobile-social-icons">
        {% comment %} 这里可以根据 settings 加入社交图标 {% endcomment %}
      </div>
    </div>
  </div>
</div>

<style>
  /* Fixed Mobile Drawer Styles */
  .drawer--left {
    left: 0;
    transform: translateX(-100%);
    width: 85%;
    max-width: 320px;
    height: 100%;
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  
  .drawer--left.is-open {
    transform: translateX(0);
  }

  .mobile-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .mobile-nav-item {
    border-bottom: 1px solid #f1f1f1;
  }
  
  .mobile-nav-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 0;
    text-decoration: none;
    color: #121212;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.1em;
    transition: padding-left 0.2s ease;
  }
  
  .mobile-nav-link:active {
    padding-left: 10px;
    background-color: #fafafa;
  }

  .mobile-nav-link.is-active {
    color: var(--color-accent);
  }

  .mobile-menu-footer {
    margin-top: 40px;
    padding-top: 30px;
    border-top: 2px solid #121212;
  }
  
  .mobile-account-links {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  
  .mobile-footer-link {
    text-decoration: none;
    color: #121212;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.15em;
  }
</style>
