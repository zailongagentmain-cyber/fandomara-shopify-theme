<section class="product-section container">
  <div class="product-layout">
    <!-- 1. Product Media -->
    <div class="product-media">
      <div class="product-main-image-wrapper">
        <img src="{{ product.featured_media | image_url: width: 1200 }}" 
             alt="{{ product.title | escape }}"
             id="MainProductImage"
             class="product-main-image">
      </div>
      <div class="product-thumbnails">
        {%- for media in product.media -%}
          <div class="thumbnail-item" onclick="document.getElementById('MainProductImage').src='{{ media | image_url: width: 1200 }}'">
            <img src="{{ media | image_url: width: 200 }}" alt="{{ media.alt | escape }}">
          </div>
        {%- endfor -%}
      </div>
    </div>

    <!-- 2. Product Info -->
    <div class="product-info-sticky">
      <div class="product-info-header">
        <h1 class="product-title-refined">{{ product.title }}</h1>
        
        <div class="product-price-refined">
          <span class="price-current">{{ product.selected_or_first_available_variant.price | money }}</span>
          {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
            <span class="price-old">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
            <span class="price-badge-sale">Sale</span>
          {%- endif -%}
        </div>
      </div>

      {%- form 'product', product, class: 'product-form-refined' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        <!-- Precision Variant Picker (Radios) -->
        {%- unless product.has_only_default_variant -%}
          <div class="variant-picker">
            {%- for option in product.options_with_values -%}
              <fieldset class="variant-input-wrapper">
                <legend class="variant-label">{{ option.name }}</legend>
                <div class="variant-options-grid">
                  {%- for value in option.values -%}
                    <input type="radio" 
                           id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                           name="{{ option.name }}"
                           value="{{ value | escape }}"
                           form="{{ product_form_id }}"
                           {% if option.selected_value == value %}checked{% endif %}
                           class="visually-hidden">
                    <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" class="variant-swatch">
                      {{ value }}
                    </label>
                  {%- endfor -%}
                </div>
              </fieldset>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <!-- Buy Buttons -->
        <div class="product-buy-buttons">
          <label class="variant-label" for="Quantity">Quantity</label>
          <div class="product-buy-row">
            <div class="quantity-input-refined">
               <button type="button" onclick="this.parentNode.querySelector('input').stepDown()">-</button>
               <input type="number" id="Quantity" name="quantity" value="1" min="1">
               <button type="button" onclick="this.parentNode.querySelector('input').stepUp()">+</button>
            </div>
            <button type="submit" name="add" class="button atc-button-precision" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
              {%- if product.selected_or_first_available_variant.available -%}
                Add to cart
              {%- else -%}
                Sold out
              {%- endif -%}
            </button>
          </div>
        </div>
      {%- endform -%}

      <!-- Accordion Description -->
      <div class="product-accordions">
        <details class="accordion" open>
          <summary class="accordion__title">
            Description 
            <svg class="icon icon-caret" width="14" height="14" viewBox="0 0 10 6" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor"></path></svg>
          </summary>
          <div class="accordion__content rte">
            {{ product.description }}
          </div>
        </details>
      </div>
    </div>
  </div>
</section>

<style>
  .product-section { padding: 4rem 0; }
  .product-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  
  .product-main-image-wrapper { background: #f3f3f3; margin-bottom: 1rem; }
  .product-main-image { width: 100%; display: block; }
  .product-thumbnails { display: flex; gap: 1rem; overflow-x: auto; scroll-snap-type: x mandatory; }
  .thumbnail-item { width: calc(25% - 0.75rem); flex-shrink: 0; cursor: pointer; scroll-snap-align: start; }
  .thumbnail-item img { width: 100%; height: auto; display: block; border: 1px solid var(--color-border); }

  .product-info-sticky { position: sticky; top: 8rem; }
  
  .product-title-refined { font-size: 3rem; margin-bottom: 1.5rem; letter-spacing: 0; }
  
  .product-price-refined { display: flex; align-items: center; gap: 1rem; margin-bottom: 3rem; }
  .price-current { font-size: 2.2rem; font-weight: 500; }
  .price-old { font-size: 1.6rem; text-decoration: line-through; color: rgba(18, 18, 18, 0.75); }
  .price-badge-sale { background: var(--color-background); border: 1px solid var(--color-border); padding: 0.6rem 1.2rem; border-radius: 4rem; font-size: 1.2rem; }

  /* Variant Picker */
  .variant-input-wrapper { border: none; padding: 0; margin: 0 0 2.5rem; }
  .variant-label { font-size: 1.4rem; margin-bottom: 1rem; display: block; }
  .variant-options-grid { display: flex; flex-wrap: wrap; gap: 1rem; }
  .variant-swatch { 
    border: 1px solid var(--color-border); 
    padding: 1rem 2rem; 
    cursor: pointer; 
    font-size: 1.4rem; 
    transition: all 0.1s ease;
    border-radius: 0;
  }
  input:checked + .variant-swatch { 
    background: var(--color-foreground); 
    color: #fff; 
    border-color: var(--color-foreground); 
  }

  /* Buy buttons */
  .product-buy-buttons { margin-bottom: 4rem; }
  .product-buy-row { display: flex; gap: 1rem; margin-top: 1rem; }
  .quantity-input-refined { 
    display: flex; 
    border: 1px solid var(--color-foreground); 
    width: 14rem; 
    height: 5rem;
  }
  .quantity-input-refined button { 
    background: none; 
    border: none; 
    width: 4.5rem; 
    font-size: 1.8rem; 
    color: var(--color-foreground); 
    cursor: pointer;
  }
  .quantity-input-refined input { 
    flex: 1; 
    border: none; 
    text-align: center; 
    font-size: 1.5rem; 
    font-family: inherit;
    background: transparent;
    color: var(--color-foreground);
    -moz-appearance: textfield;
  }
  .quantity-input-refined input::-webkit-outer-spin-button,
  .quantity-input-refined input::-webkit-inner-spin-button {
    -webkit-appearance: none; margin: 0;
  }
  
  .atc-button-precision { 
    flex: 1; 
    height: 5rem;
  }

  /* Accordions */
  .product-accordions { border-top: 1px solid var(--color-border); }
  .accordion { border-bottom: 1px solid var(--color-border); }
  .accordion__title {
    padding: 2rem 0;
    list-style: none;
    cursor: pointer;
    font-size: 1.5rem;
    font-weight: 600;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .accordion__title::-webkit-details-marker { display: none; }
  details[open] .icon-caret { transform: rotate(180deg); }
  .accordion__content { padding-bottom: 2rem; font-size: 1.5rem; line-height: 1.6; }

  @media (max-width: 990px) {
    .product-layout { grid-template-columns: 1fr; }
    .product-title-refined { font-size: 2.4rem; }
  }
</style>
