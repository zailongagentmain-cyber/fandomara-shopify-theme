<section class="product-section container">
  <div class="product-layout">
    <!-- 1. Product Media -->
    <div class="product-media">
      <div class="product-main-image-wrapper">
        <img src="{{ product.featured_media | image_url: width: 1200 }}" 
             alt="{{ product.title | escape }}"
             id="MainProductImage"
             class="product-main-image">
      </div>
      <div class="product-thumbnails">
        {%- for media in product.media -%}
          <div class="thumbnail-item" onclick="document.getElementById('MainProductImage').src='{{ media | image_url: width: 1200 }}'">
            <img src="{{ media | image_url: width: 200 }}" alt="{{ media.alt | escape }}">
          </div>
        {%- endfor -%}
      </div>
    </div>

    <!-- 2. Product Info -->
    <div class="product-info-sticky">
      <div class="product-info-header">
        <p class="product-vendor">{{ product.vendor | uppercase }}</p>
        <h1 class="product-title-large">{{ product.title }}</h1>
        <div class="product-price-large">
          <span class="price-current">{{ product.selected_or_first_available_variant.price | money }}</span>
          {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
            <span class="price-old">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
          {%- endif -%}
        </div>
      </div>

      {%- form 'product', product, class: 'product-form-refined' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        {%- unless product.has_only_default_variant -%}
          <div class="product-options-wrapper">
            {%- for option in product.options_with_values -%}
              <div class="option-row">
                <label class="option-label">{{ option.name }}</label>
                <div class="option-swatches">
                  {%- for value in option.values -%}
                    <label class="swatch-label">
                      <input type="radio" name="{{ option.name }}" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %} class="visually-hidden">
                      <span class="swatch-text">{{ value }}</span>
                    </label>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <div class="product-buy-row">
          <div class="quantity-selector-refined">
            <button type="button" onclick="this.parentNode.querySelector('input').stepDown()">-</button>
            <input type="number" name="quantity" value="1" min="1">
            <button type="button" onclick="this.parentNode.querySelector('input').stepUp()">+</button>
          </div>
          <button type="submit" name="add" class="add-to-cart-refined-btn" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
            {%- if product.selected_or_first_available_variant.available -%}
              ADD TO CART
            {%- else -%}
              SOLD OUT
            {%- endif -%}
          </button>
        </div>
      {%- endform -%}

      <div class="product-description-refined rte">
        {{ product.description }}
      </div>
    </div>
  </div>
</section>

<style>
  .product-section { padding: 80px 0; }
  .product-layout { display: grid; grid-template-columns: 1.4fr 1fr; gap: 80px; align-items: start; }
  
  .product-main-image-wrapper { background: #f9f9f9; border: 1px solid #eee; position: sticky; top: 120px; }
  .product-main-image { width: 100%; display: block; }
  .product-thumbnails { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; }
  .thumbnail-item { width: 70px; aspect-ratio: 1; cursor: pointer; border: 1px solid #eee; overflow: hidden; }
  .thumbnail-item img { width: 100%; height: 100%; object-fit: cover; }

  .product-info-sticky { position: sticky; top: 120px; }
  .product-vendor { font-size: 12px; letter-spacing: 0.2em; color: #888; margin-bottom: 10px; }
  .product-title-large { font-size: 32px; font-weight: 800; text-transform: uppercase; line-height: 1.2; margin-bottom: 20px; }
  .product-price-large { margin-bottom: 40px; }
  .price-current { font-size: 24px; font-weight: 700; color: #000; }
  .price-old { font-size: 18px; text-decoration: line-through; color: #999; margin-left: 15px; }

  .option-row { margin-bottom: 30px; }
  .option-label { display: block; font-size: 13px; font-weight: 700; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 0.1em; }
  .option-swatches { display: flex; gap: 10px; flex-wrap: wrap; }
  .swatch-text { display: block; padding: 10px 20px; border: 1px solid #ddd; font-size: 13px; cursor: pointer; transition: all 0.2s; }
  input:checked + .swatch-text { border-color: #000; background: #000; color: #fff; }

  .product-buy-row { display: flex; gap: 15px; margin-top: 40px; }
  .quantity-selector-refined { display: flex; border: 1px solid #ddd; }
  .quantity-selector-refined button { background: none; border: none; padding: 0 15px; cursor: pointer; font-size: 18px; }
  .quantity-selector-refined input { width: 40px; border: none; text-align: center; font-weight: bold; }
  
  .add-to-cart-refined-btn { flex: 1; padding: 18px; background: #000; color: #fff; border: none; font-weight: 800; letter-spacing: 0.2em; cursor: pointer; }
  .add-to-cart-refined-btn:hover { background: #333; }

  .product-description-refined { margin-top: 50px; border-top: 1px solid #eee; padding-top: 30px; line-height: 1.8; color: #444; }

  @media (max-width: 990px) {
    .product-layout { grid-template-columns: 1fr; gap: 40px; }
    .product-title-large { font-size: 24px; }
  }
</style>
