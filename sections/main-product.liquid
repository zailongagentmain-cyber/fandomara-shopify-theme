<section class="product-section container">
  <div class="product-layout">
    <!-- 1. Product Media (Left) -->
    <div class="product-media">
      <div class="product-main-image-wrapper">
        <img src="{{ product.featured_media | image_url: width: 1200 }}" 
             alt="{{ product.title | escape }}"
             id="MainProductImage"
             class="product-main-image">
      </div>
      <div class="product-thumbnails">
        {%- for media in product.media -%}
          <div class="thumbnail-item" onclick="document.getElementById('MainProductImage').src='{{ media | image_url: width: 1200 }}'">
            <img src="{{ media | image_url: width: 200 }}" alt="{{ media.alt | escape }}">
          </div>
        {%- endfor -%}
      </div>
    </div>

    <!-- 2. Product Info (Right) -->
    <div class="product-info-sticky">
      <div class="product-info-header">
        <p class="product-vendor">{{ product.vendor | uppercase }}</p>
        <h1 class="product-title-refined">{{ product.title }}</h1>
        
        <div class="product-price-refined">
          <span class="price-current">{{ product.selected_or_first_available_variant.price | money }}</span>
          {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
            <span class="price-old">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
            <span class="price-badge-sale">SALE</span>
          {%- endif -%}
        </div>
      </div>

      {%- form 'product', product, class: 'product-form-refined' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        <!-- Precision Variant Picker (Radios) -->
        {%- unless product.has_only_default_variant -%}
          <div class="variant-picker">
            {%- for option in product.options_with_values -%}
              <fieldset class="variant-input-wrapper">
                <legend class="variant-label">{{ option.name }}: <span id="SelectedValue-{{ forloop.index }}">{{ option.selected_value }}</span></legend>
                <div class="variant-options-grid">
                  {%- for value in option.values -%}
                    <input type="radio" 
                           id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                           name="{{ option.name }}"
                           value="{{ value | escape }}"
                           form="{{ product_form_id }}"
                           {% if option.selected_value == value %}checked{% endif %}
                           class="visually-hidden">
                    <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" class="variant-swatch">
                      {{ value }}
                    </label>
                  {%- endfor -%}
                </div>
              </fieldset>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <!-- Buy Buttons -->
        <div class="product-buy-buttons">
          <div class="quantity-input-refined">
             <button type="button" onclick="this.parentNode.querySelector('input').stepDown()">-</button>
             <input type="number" name="quantity" value="1" min="1">
             <button type="button" onclick="this.parentNode.querySelector('input').stepUp()">+</button>
          </div>
          <button type="submit" name="add" class="atc-button-precision" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
            {%- if product.selected_or_first_available_variant.available -%}
              ADD TO CART
            {%- else -%}
              SOLD OUT
            {%- endif -%}
          </button>
        </div>
      {%- endform -%}

      <!-- Accordion Description (Precision) -->
      <div class="product-accordions">
        <details open>
          <summary>DESCRIPTION <span class="icon">+</span></summary>
          <div class="accordion-content rte">
            {{ product.description }}
          </div>
        </details>
        <details>
          <summary>SHIPPING POLICY <span class="icon">+</span></summary>
          <div class="accordion-content">
            <p>Free standard shipping on orders over $50. Processing time 2-4 business days.</p>
          </div>
        </details>
      </div>
    </div>
  </div>
</section>

<style>
  /* Refined PDP Styles */
  .product-section { padding: 60px 0; }
  .product-layout { display: grid; grid-template-columns: 1.3fr 1fr; gap: 60px; }
  
  .product-title-refined { font-size: 2.4rem; font-weight: 600; line-height: 1.2; margin: 0 0 15px; color: #121212; letter-spacing: -0.01em; }
  .product-vendor { font-size: 11px; letter-spacing: 0.2em; color: rgba(18, 18, 18, 0.5); margin-bottom: 8px; }
  
  .product-price-refined { display: flex; align-items: center; gap: 15px; margin-bottom: 30px; }
  .price-current { font-size: 1.8rem; font-weight: 500; color: #121212; }
  .price-old { color: rgba(18, 18, 18, 0.5); text-decoration: line-through; font-size: 1.4rem; }
  .price-badge-sale { background: #f3f3f3; color: #121212; padding: 4px 12px; border-radius: 40px; font-size: 1.2rem; }

  /* Variant Picker Precision */
  .variant-input-wrapper { border: none; padding: 0; margin: 0 0 25px; }
  .variant-label { font-size: 1.3rem; font-weight: 600; margin-bottom: 12px; text-transform: uppercase; }
  .variant-label span { font-weight: 400; color: #666; }
  .variant-options-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .variant-swatch { 
    border: 1px solid rgba(18, 18, 18, 0.1); 
    padding: 10px 20px; 
    cursor: pointer; 
    font-size: 1.3rem; 
    transition: all 0.2s ease;
  }
  input:checked + .variant-swatch { 
    background: #121212; 
    color: #fff; 
    border-color: #121212; 
  }

  /* ATC Button Precision */
  .product-buy-buttons { display: flex; gap: 10px; margin-top: 35px; }
  .quantity-input-refined { display: flex; border: 1px solid rgba(18, 18, 18, 0.1); width: 120px; }
  .quantity-input-refined button { flex: 1; background: none; border: none; cursor: pointer; font-size: 18px; }
  .quantity-input-refined input { width: 40px; border: none; text-align: center; font-weight: 600; }
  
  .atc-button-precision { 
    flex: 2; 
    height: 50px; 
    background: #121212; 
    color: #fff; 
    border: none; 
    font-weight: 600; 
    letter-spacing: 0.1em; 
    cursor: pointer;
    transition: box-shadow 0.1s ease;
  }
  .atc-button-precision:hover { box-shadow: 0 0 0 0.1rem #121212; }

  /* Accordion Precision */
  .product-accordions { margin-top: 40px; border-top: 1px solid #eee; }
  details { border-bottom: 1px solid #eee; }
  summary { 
    padding: 15px 0; 
    list-style: none; 
    cursor: pointer; 
    font-weight: 600; 
    font-size: 1.2rem; 
    letter-spacing: 0.15em; 
    display: flex; 
    justify-content: space-between; 
  }
  summary::-webkit-details-marker { display: none; }
  .accordion-content { padding-bottom: 20px; font-size: 1.4rem; color: #444; line-height: 1.6; }

  @media (max-width: 990px) {
    .product-layout { grid-template-columns: 1fr; }
  }
</style>
