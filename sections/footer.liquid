<footer class="footer">
  <div class="container">
    <div class="footer__blocks-wrapper">
      {%- for block in section.blocks -%}
        <div class="footer-block" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h2 class="footer-block__heading">{{ block.settings.heading | escape }}</h2>
          {%- endif -%}

          {%- case block.type -%}
            {%- when 'text' -%}
              <div class="footer-block__details-content rte">
                {{ block.settings.subtext }}
              </div>
            {%- when 'link_list' -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer-block__details-content list-unstyled">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="link list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}">
                        {{ link.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="footer__content-bottom">
      <div class="footer__column footer__column--info">
        <div class="footer__copyright">
          <small class="copyright__content">&copy; {{ 'now' | date: "%Y" }}, {{ shop.name | link_to: routes.root_url }}</small>
          <small class="copyright__content">Powered by Shopify</small>
        </div>
        <div class="footer__payment">
          <span class="visually-hidden">Payment methods</span>
          <ul class="list list-payment" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li class="list-payment__item">
                {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 0.1rem solid var(--color-border);
    padding: 5rem 0;
    margin-top: 5rem;
    background-color: var(--color-background);
  }

  .footer__blocks-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 4rem;
    margin-bottom: 5rem;
  }

  .footer-block {
    flex: 1 1 calc(25% - 4rem);
    min-width: 25rem;
  }

  .footer-block__heading {
    font-size: 1.6rem;
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .footer-block__details-content {
    font-size: 1.4rem;
    color: var(--color-foreground);
    opacity: 0.75;
  }

  .list-unstyled {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu__item {
    display: block;
    padding-bottom: 1.5rem;
    color: var(--color-foreground);
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.3s;
  }

  .list-menu__item:hover {
    opacity: 1;
  }

  .footer__content-bottom {
    border-top: 0.1rem solid var(--color-border);
    padding-top: 3rem;
  }

  .footer__column--info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer__copyright {
    display: flex;
    gap: 1rem;
    font-size: 1.2rem;
    opacity: 0.75;
  }

  .list-payment {
    display: flex;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-payment__item svg {
    width: 3.8rem;
    height: 2.4rem;
  }

  @media screen and (max-width: 749px) {
    .footer__column--info {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .footer__blocks-wrapper {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Quick links",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p>Share contact information, store details, and brand content with your customers.</p>",
          "label": "Subtext"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list"
      },
      {
        "type": "text"
      }
    ]
  }
}
{% endschema %}
