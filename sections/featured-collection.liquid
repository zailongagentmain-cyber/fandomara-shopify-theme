<div class="featured-collection container section-{{ section.id }}">
  <div class="section-header">
    <h2 class="section-header__title">{{ section.settings.title | escape }}</h2>
    {%- if section.settings.view_all and section.settings.collection != blank -%}
      <a href="{{ section.settings.collection.url }}" class="section-header__link">
        View all
      </a>
    {%- endif -%}
  </div>

  <div class="product-grid">
    {%- assign collection = section.settings.collection -%}
    {%- for product in collection.products limit: section.settings.products_to_show -%}
      <div class="product-grid__item">
        {% render 'product-card', product: product %}
      </div>
    {%- else -%}
      {%- for i in (1..section.settings.products_to_show) -%}
        <div class="product-grid__item">
           <div class="product-card">
              <div class="product-card__image-wrapper">
                 {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="product-card__info">
                 <h3 class="product-card__title">Example Product {{ i }}</h3>
                 <p class="product-card__price">$29.99</p>
              </div>
           </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
  
  {%- if section.settings.show_view_all_button and section.settings.collection != blank -%}
    <div class="center" style="margin-top: 5rem; text-align: center;">
      <a href="{{ section.settings.collection.url }}" class="button button--secondary">
        View all products
      </a>
    </div>
  {%- endif -%}
</div>

<style>
  .featured-collection {
    padding: 6rem 0;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
  }
  .section-header__title {
    font-size: 3rem;
    margin: 0;
    letter-spacing: 0;
  }
  .section-header__link {
    font-size: 1.5rem;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 0.3rem;
  }
  .section-header__link:hover {
    color: var(--color-button);
  }
  
  .placeholder-svg {
    width: 100%;
    height: 100%;
    background-color: var(--color-border);
    fill: rgba(18, 18, 18, 0.5);
  }

  @media (max-width: 990px) {
    .section-header__title { font-size: 2.4rem; }
  }
</style>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Featured collection" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "default": 4, "label": "Maximum products" },
    { "type": "checkbox", "id": "view_all", "label": "Enable 'View all' link in header", "default": false },
    { "type": "checkbox", "id": "show_view_all_button", "label": "Enable 'View all' button below grid", "default": true }
  ],
  "presets": [
    { "name": "Featured Collection" }
  ]
}
{% endschema %}
