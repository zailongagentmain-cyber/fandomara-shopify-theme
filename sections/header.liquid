{%- if section.settings.show_announcement -%}
  <div class="announcement-bar">
    <div class="container">
      {{ section.settings.announcement_text }}
    </div>
  </div>
{%- endif -%}

<div class="header-wrapper">
  <div class="container">
    <header class="header">
      <!-- Hamburger (Mobile Only) / Search (Desktop) -->
      <div class="header__icons header__icons--left">
        <button type="button" class="mobile-menu-trigger icon-link" aria-label="Menu" onclick="openDrawer('MobileMenu')">
           <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
        <a href="{{ routes.search_url }}" class="icon-link desktop-search" aria-label="Search">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </a>
      </div>

      <!-- Logo -->
      <div class="header__logo">
        <a href="{{ routes.root_url }}" style="display: inline-block;">
          {%- if section.settings.logo_image != blank -%}
             <img src="{{ section.settings.logo_image | image_url: width: 300 }}" alt="{{ shop.name }}" style="max-height: 80px; width: auto; vertical-align: middle;">
          {%- else -%}
             <span style="font-size: 2.4rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <!-- Icons -->
      <div class="header__icons">
        {%- if shop.customer_accounts_enabled -%}
          <a href="{{ routes.account_login_url }}" class="icon-link desktop-only" aria-label="Account">
             <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </a>
        {%- endif -%}
        <button type="button" class="icon-link" aria-label="Cart" onclick="openDrawer('CartDrawer')" style="position: relative; background: none; border: none; padding: 0;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
          <span class="cart-count-badge" id="CartCount">
            {%- if cart.item_count > 0 -%}{{ cart.item_count }}{%- else -%}0{%- endif -%}
          </span>
        </button>
      </div>
    </header>

    <!-- Navigation -->
    <nav class="header__nav desktop-only">
      <ul>
        {%- for link in section.settings.menu.links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>
    </nav>
  </div>
</div>

<style>
  .mobile-menu-trigger { display: none; background: none; border: none; cursor: pointer; padding: 0; }
  .desktop-only { display: block; }
  
  .cart-count-badge {
    position: absolute;
    top: -8px;
    right: -10px;
    background-color: var(--color-foreground);
    color: var(--color-background);
    font-size: 1rem;
    font-weight: 700;
    min-width: 1.8rem;
    height: 1.8rem;
    border-radius: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.4rem;
  }
  
  @media (max-width: 990px) {
    .header__nav { display: none; }
  }
  
  @media (max-width: 768px) {
    .mobile-menu-trigger { display: block; }
    .desktop-search, .desktop-only { display: none; }
    .header { grid-template-columns: 1fr auto 1fr; }
    .header__logo img { max-height: 50px; }
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement", "default": true },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "Opening Sale: 30% OFF + Free Shipping" },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ]
}
{% endschema %}
