<div class="hero-banner">
  {%- for block in section.blocks -%}
    <div class="hero-banner__slide" {{ block.shopify_attributes }}>
      {%- if block.settings.image != blank -%}
        <img src="{{ block.settings.image | image_url: width: 2000 }}" 
             alt="{{ block.settings.image.alt | escape }}"
             loading="lazy"
             class="hero-banner__image">
      {%- else -%}
        <img src="{{ 'banner_2000x.jpg' | asset_url }}" alt="Fandomara Banner" class="hero-banner__image">
      {%- endif -%}
      
      <div class="hero-banner__content-box">
        {%- if block.settings.heading != blank -%}
          <h2 class="hero-banner__heading">{{ block.settings.heading | escape }}</h2>
        {%- else -%}
          <h2 class="hero-banner__heading">Welcome to<br>Fandomara</h2>
        {%- endif -%}
        
        {%- if block.settings.button_label != blank -%}
          <a href="{{ block.settings.button_link }}" class="button hero-banner__button">
            {{ block.settings.button_label | escape }}
          </a>
        {%- else -%}
          <a href="/collections/all" class="button hero-banner__button">Shop All</a>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
</div>

<style>
  .hero-banner {
    position: relative;
    width: 100%;
    background-color: var(--color-background);
  }
  .hero-banner__slide {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 55rem;
    overflow: hidden;
  }
  @media screen and (min-width: 750px) {
    .hero-banner__slide {
      min-height: 65rem;
    }
  }
  
  .hero-banner__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  
  .hero-banner__content-box {
    position: relative;
    z-index: 2;
    background: var(--color-background);
    padding: 4rem 3rem;
    text-align: center;
    max-width: 60rem;
    box-shadow: 0 0.4rem 0.5rem rgba(0, 0, 0, 0.05);
  }
  
  .hero-banner__heading {
    font-size: 3.6rem;
    color: var(--color-foreground);
    margin-bottom: 2.5rem;
    letter-spacing: 0;
    text-transform: none;
  }
  
  .hero-banner__button {
    font-size: 1.6rem;
    padding: 1.2rem 4rem;
  }
  
  @media screen and (max-width: 749px) {
    .hero-banner__slide {
      flex-direction: column;
      justify-content: flex-end;
    }
    .hero-banner__content-box {
      width: 100%;
      max-width: none;
      padding: 3rem 2rem;
    }
    .hero-banner__heading {
      font-size: 2.8rem;
    }
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "text", "id": "button_label", "label": "Button label" },
        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    { "name": "Hero Banner", "blocks": [{ "type": "slide" }] }
  ]
}
{% endschema %}
