<div class="hero-banner">
  {%- for block in section.blocks -%}
    <div class="hero-banner__slide" {{ block.shopify_attributes }}>
      {%- if block.settings.image != blank -%}
        <img src="{{ block.settings.image | image_url: width: 2000 }}" 
             alt="{{ block.settings.image.alt | escape }}"
             loading="lazy"
             class="hero-banner__image">
      {%- else -%}
        <img src="{{ 'banner_2000x.jpg' | asset_url }}" alt="Fandomara Banner" class="hero-banner__image">
      {%- endif -%}
      
      <div class="hero-banner__content container">
        <div class="hero-banner__text-wrapper">
          {%- if block.settings.heading != blank -%}
            <h2 class="hero-banner__heading">{{ block.settings.heading | escape }}</h2>
          {%- else -%}
            <h2 class="hero-banner__heading">BODY PILLOW<br>COLLECTION</h2>
          {%- endif -%}
          
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link }}" class="hero-banner__button">
              {{ block.settings.button_label | escape }}
            </a>
          {%- else -%}
            <a href="/collections/all" class="hero-banner__button">SHOP NOW</a>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endfor -%}
</div>

<style>
  .hero-banner {
    position: relative;
    width: 100%;
    background: #000;
  }
  .hero-banner__slide {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .hero-banner__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  .hero-banner__content {
    position: relative;
    z-index: 2;
    color: white;
  }
  .hero-banner__text-wrapper {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Overlay for text readability */
  .hero-banner__slide::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.1);
    z-index: 1;
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "text", "id": "button_label", "label": "Button label" },
        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    { "name": "Hero Banner", "blocks": [{ "type": "slide" }] }
  ]
}
{% endschema %}
